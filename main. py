import os
import shutil

# Aap jis folder ko saaf karna chahte hain uska rasta (path)
# Agar aapko download folder organize karna hai to yahan uska path likhein
folder_path = './' 

def organize_files():
    for filename in os.listdir(folder_path):
        if os.path.isfile(os.path.join(folder_path, filename)):
            # File ki extension check karein
            extension = filename.split('.')[-1].lower()
            
            if extension in ['jpg', 'png', 'jpeg']:
                target_folder = 'Images'
            elif extension in ['pdf', 'docx', 'txt']:
                target_folder = 'Documents'
            elif extension in ['mp4', 'mkv']:
                target_folder = 'Videos'
            else:
                target_folder = 'Others'
            
            # Naya folder banayein agar nahi hai
            if not os.path.exists(os.path.join(folder_path, target_folder)):
                os.makedirs(os.path.join(folder_path, target_folder))
            
            # File ko move karein
            shutil.move(os.path.join(folder_path, filename), 
                        os.path.join(folder_path, target_folder, filename))
            print(f"Moved {filename} to {target_folder}")

if __name__ == "__main__":
    organize_files()
    print("Files organized successfully
